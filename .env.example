DB_HOST=
DB_PORT=
DB_USERNAME=
DB_PASSWORD=
DB_DATABASE=
DB_SSL_MODE=disable

# Optional: separate admin DB credentials (falls back to DB_USERNAME/DB_PASSWORD if not set)
DB_ADMIN_USERNAME=
DB_ADMIN_PASSWORD=

# Zitadel OIDC (replaces JWT_SECRET)
ZITADEL_ISSUER=https://auth.tokyosushibarliege.be
ZITADEL_INTERNAL_URL=
ZITADEL_CLIENT_ID=
ZITADEL_NATIVE_CLIENT_ID=
ZITADEL_SERVICE_PAT=
ZITADEL_ADMIN_PAT=

APP_ENV=development
LOG_LEVEL=info
LOG_FORMAT=text

MOLLIE_API_TOKEN=
MOLLIE_TESTING=true
MOLLIE_WEBHOOK_URL=

ENABLE_GQL_INTROSPECTION=true

APP_BASE_URL=
API_BASE_URL=
APP_DASHBOARD_URL=

# Google Maps API (for address autocomplete, place details, and distance matrix)
GOOGLE_MAPS_API_KEY=
RESTAURANT_ORIGIN_LAT=50.64245770697728
RESTAURANT_ORIGIN_LNG=5.574703166758179
GOOGLE_MAPS_LANGUAGE=fr
# Restrict autocomplete suggestions to a circle around the restaurant.
# 0 disables; 15 000 m covers greater Liège and skips useless suggestions.
AUTOCOMPLETE_RADIUS_METERS=15000

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=
AWS_REGION=
AWS_BUCKET=
AWS_URL=

# File service (S3 image upload/rename/delete)
FILE_SERVICE_URL=

# Zitadel social IdP IDs (from Zitadel console → Identity Providers)
ZITADEL_IDP_GOOGLE_ID=
ZITADEL_IDP_APPLE_ID=

SCW_ACCESS_KEY=
SCW_SECRET_KEY=
SCW_DEFAULT_ORGANIZATION_ID=
SCW_DEFAULT_PROJECT_ID=
SCW_SENDER_EMAIL=
SCW_SENDER_NAME=
SCW_REGION="fr-par"

# APNs (iOS push notifications — optional, app works without)
APNS_AUTH_KEY_PATH=
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=be.tokyosushibarliege.app

# FCM (Android push notifications — optional, app works without)
# Set to the path of the Firebase service account JSON file
GOOGLE_APPLICATION_CREDENTIALS=

# Cloudflare Turnstile (bot protection — optional, skipped if empty)
TURNSTILE_SECRET_KEY=

# POS (tsb-pos-android) auth — HS256 signing key for RRN-issued app JWTs.
# Must be at least 32 random bytes; rotate to invalidate all POS sessions.
# If unset, the server generates an ephemeral key at boot (all tokens invalid
# across restarts — fine for dev, not for prod).
POS_JWT_SECRET=
