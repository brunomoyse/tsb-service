DB_HOST=
DB_PORT=
DB_USERNAME=
DB_PASSWORD=
DB_DATABASE=
DB_SSL_MODE=disable

# Optional: separate admin DB credentials (falls back to DB_USERNAME/DB_PASSWORD if not set)
DB_ADMIN_USERNAME=
DB_ADMIN_PASSWORD=

# Zitadel OIDC (replaces JWT_SECRET)
ZITADEL_ISSUER=https://auth.tokyosushibarliege.be
ZITADEL_INTERNAL_URL=
ZITADEL_CLIENT_ID=
ZITADEL_NATIVE_CLIENT_ID=
ZITADEL_SERVICE_PAT=
ZITADEL_ADMIN_PAT=

APP_ENV=development
LOG_LEVEL=info
LOG_FORMAT=text

MOLLIE_API_TOKEN=
MOLLIE_TESTING=true
MOLLIE_WEBHOOK_URL=

ENABLE_GQL_INTROSPECTION=true

APP_BASE_URL=
API_BASE_URL=
APP_DASHBOARD_URL=

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=
AWS_REGION=
AWS_BUCKET=
AWS_URL=

# File service (S3 image upload/rename/delete)
FILE_SERVICE_URL=

# Zitadel social IdP IDs (from Zitadel console → Identity Providers)
ZITADEL_IDP_GOOGLE_ID=
ZITADEL_IDP_APPLE_ID=

SCW_ACCESS_KEY=
SCW_SECRET_KEY=
SCW_DEFAULT_ORGANIZATION_ID=
SCW_DEFAULT_PROJECT_ID=
SCW_SENDER_EMAIL=
SCW_SENDER_NAME=
SCW_REGION="fr-par"

# APNs (iOS push notifications — optional, app works without)
APNS_AUTH_KEY_PATH=
APNS_KEY_ID=
APNS_TEAM_ID=
APNS_BUNDLE_ID=be.tokyosushibarliege.app

# FCM (Android push notifications — optional, app works without)
# Set to the path of the Firebase service account JSON file
GOOGLE_APPLICATION_CREDENTIALS=

# Cloudflare Turnstile (bot protection — optional, skipped if empty)
TURNSTILE_SECRET_KEY=
